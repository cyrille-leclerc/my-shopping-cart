set -euo pipefail

kubectl create namespace ecommerce || echo "WARNING: Could not create namespace 'ecommerce' (may already exist or insufficient permissions). Continuing..."

kubectl label namespace ecommerce admission.datadoghq.com/enabled=true --overwrite

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

kubectl apply -n ecommerce -f "$SCRIPT_DIR"